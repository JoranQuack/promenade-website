# Outstatic repository defaults for this project
OST_REPO_OWNER=JoranQuack
OST_REPO_SLUG=promenade-website
OST_REPO_BRANCH=main

# Required for self-hosted GitHub sign-in on /outstatic
# Create a GitHub OAuth App and set callback URL to:
# http://localhost:3000/api/outstatic/callback
OST_GITHUB_ID=
OST_GITHUB_SECRET=
OST_GITHUB_CALLBACK_URL=http://localhost:3000/api/outstatic/callback
