# Optional explicit repository settings
# OST_REPO_OWNER=your-github-username-or-org
# OST_REPO_SLUG=promenade-website
# OST_REPO_BRANCH=main

# Self-hosted auth (required if you are not using Outstatic cloud auth flow)
# OST_GITHUB_ID=your_github_oauth_app_client_id
# OST_GITHUB_SECRET=your_github_oauth_app_client_secret
# OST_GITHUB_CALLBACK_URL=http://localhost:3000/api/outstatic/callback

# Optional path customizations
# OST_CONTENT_PATH=outstatic/content
# OST_OUTSTATIC_PATH=outstatic
# OST_BASE_PATH=
